      "glsl1": {
        "vert": "\nprecision highp float;\nuniform mat4 cc_matViewProj;\nuniform mat4 cc_matWorld;\nattribute vec3 a_position;\nattribute vec4 a_color;\nvarying vec4 v_color;\n#if USE_TEXTURE\nattribute vec2 a_uv0;\nvarying vec2 v_uv0;\n#endif\nvoid main () {\n  vec4 pos = vec4(a_position, 1.0);\n  #if CC_USE_MODEL\n  pos = cc_matViewProj * cc_matWorld * pos;\n  #else\n  pos = cc_matViewProj * pos;\n  #endif\n  #if USE_TEXTURE\n  v_uv0 = a_uv0;\n  #endif\n  v_color = a_color;\n  gl_Position = pos;\n}",
        "frag": "\nprecision highp float;\n#if USE_ALPHA_TEST\n  uniform float alphaThreshold;\n#endif\nvoid ALPHA_TEST (in vec4 color) {\n  #if USE_ALPHA_TEST\n      if (color.a < alphaThreshold) discard;\n  #endif\n}\nvoid ALPHA_TEST (in float alpha) {\n  #if USE_ALPHA_TEST\n      if (alpha < alphaThreshold) discard;\n  #endif\n}\nvarying vec4 v_color;\n#if USE_TEXTURE\nvarying vec2 v_uv0;\nuniform sampler2D texture;\n#endif\nuniform vec2 center;\nuniform float progress;\nuniform float amplitude;\nuniform float bandWidth;\nuniform float aspect;\nuniform float brightness;\nvoid main () {\n  vec4 baseColor = vec4(1.0, 1.0, 1.0, 1.0);\n  #if USE_TEXTURE\n  baseColor *= texture2D(texture, v_uv0);\n    #if CC_USE_ALPHA_ATLAS_TEXTURE\n    baseColor.a *= texture2D(texture, v_uv0 + vec2(0, 0.5)).r;\n    #endif\n  #endif\n  baseColor *= v_color;\n  ALPHA_TEST(baseColor);\n  vec2 radial = v_uv0 - center;\n  radial.x *= aspect;\n  float dist = length(radial);\n  vec2 dir = dist > 0.0001 ? radial / dist : vec2(0.0, 1.0);\n  float waveFront = 0.06 + progress * 0.62;\n  float ring = 1.0 - smoothstep(bandWidth * 0.22, bandWidth, abs(dist - waveFront));\n  float falloff = 1.0 - smoothstep(0.0, 0.95, progress);\n  float phase = (dist - waveFront) * 92.0 - progress * 18.0;\n  float offsetAmount = sin(phase) * amplitude * ring * (0.45 + 0.55 * falloff);\n  vec2 offset = vec2(dir.x / max(aspect, 0.001), dir.y) * offsetAmount;\n  vec4 warped = baseColor;\n  #if USE_TEXTURE\n  warped = texture2D(texture, v_uv0 + offset);\n    #if CC_USE_ALPHA_ATLAS_TEXTURE\n    warped.a *= texture2D(texture, v_uv0 + offset + vec2(0, 0.5)).r;\n    #endif\n  #endif\n  float edgeGlow = ring * (brightness + falloff * 0.08);\n  vec3 finalColor = warped.rgb + vec3(edgeGlow);\n  float alpha = clamp(ring * (0.5 + falloff * 0.35), 0.0, 1.0);\n  gl_FragColor = vec4(finalColor, alpha);\n}"
      },
      "glsl3": {
        "vert": "\nprecision highp float;\nuniform CCGlobal {\n  mat4 cc_matView;\n  mat4 cc_matViewInv;\n  mat4 cc_matProj;\n  mat4 cc_matProjInv;\n  mat4 cc_matViewProj;\n  mat4 cc_matViewProjInv;\n  vec4 cc_cameraPos;\n  vec4 cc_time;\n  mediump vec4 cc_screenSize;\n  mediump vec4 cc_screenScale;\n};\nuniform CCLocal {\n  mat4 cc_matWorld;\n  mat4 cc_matWorldIT;\n};\nin vec3 a_position;\nin vec4 a_color;\nout vec4 v_color;\n#if USE_TEXTURE\nin vec2 a_uv0;\nout vec2 v_uv0;\n#endif\nvoid main () {\n  vec4 pos = vec4(a_position, 1.0);\n  #if CC_USE_MODEL\n  pos = cc_matViewProj * cc_matWorld * pos;\n  #else\n  pos = cc_matViewProj * pos;\n  #endif\n  #if USE_TEXTURE\n  v_uv0 = a_uv0;\n  #endif\n  v_color = a_color;\n  gl_Position = pos;\n}",
        "frag": "\nprecision highp float;\n#if USE_ALPHA_TEST\n  uniform ALPHA_TEST {\n    float alphaThreshold;\n  };\n#endif\nvoid ALPHA_TEST (in vec4 color) {\n  #if USE_ALPHA_TEST\n      if (color.a < alphaThreshold) discard;\n  #endif\n}\nvoid ALPHA_TEST (in float alpha) {\n  #if USE_ALPHA_TEST\n      if (alpha < alphaThreshold) discard;\n  #endif\n}\nin vec4 v_color;\n#if USE_TEXTURE\nin vec2 v_uv0;\nuniform sampler2D texture;\n#endif\nuniform Ripple {\n  vec2 center;\n  float progress;\n  float amplitude;\n  float bandWidth;\n  float aspect;\n  float brightness;\n};\nvoid main () {\n  vec4 baseColor = vec4(1.0, 1.0, 1.0, 1.0);\n  #if USE_TEXTURE\n  baseColor *= texture(texture, v_uv0);\n    #if CC_USE_ALPHA_ATLAS_TEXTURE\n    baseColor.a *= texture2D(texture, v_uv0 + vec2(0, 0.5)).r;\n    #endif\n  #endif\n  baseColor *= v_color;\n  ALPHA_TEST(baseColor);\n  vec2 radial = v_uv0 - center;\n  radial.x *= aspect;\n  float dist = length(radial);\n  vec2 dir = dist > 0.0001 ? radial / dist : vec2(0.0, 1.0);\n  float waveFront = 0.06 + progress * 0.62;\n  float ring = 1.0 - smoothstep(bandWidth * 0.22, bandWidth, abs(dist - waveFront));\n  float falloff = 1.0 - smoothstep(0.0, 0.95, progress);\n  float phase = (dist - waveFront) * 92.0 - progress * 18.0;\n  float offsetAmount = sin(phase) * amplitude * ring * (0.45 + 0.55 * falloff);\n  vec2 offset = vec2(dir.x / max(aspect, 0.001), dir.y) * offsetAmount;\n  vec4 warped = baseColor;\n  #if USE_TEXTURE\n  warped = texture(texture, v_uv0 + offset);\n    #if CC_USE_ALPHA_ATLAS_TEXTURE\n    warped.a *= texture2D(texture, v_uv0 + offset + vec2(0, 0.5)).r;\n    #endif\n  #endif\n  float edgeGlow = ring * (brightness + falloff * 0.08);\n  vec3 finalColor = warped.rgb + vec3(edgeGlow);\n  float alpha = clamp(ring * (0.5 + falloff * 0.35), 0.0, 1.0);\n  gl_FragColor = vec4(finalColor, alpha);\n}"
